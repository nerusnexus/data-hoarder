<ui:FluentWindow x:Class="DataHoarder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:DataHoarder.Views" 
        Title="YT-DLP Hoarder" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" ExtendsContentIntoTitleBar="True">
    <Grid>
        <ui:NavigationView x:Name="RootNavigation" PaneDisplayMode="Left">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Subscriptions" TargetPageType="{x:Type views:DashboardPage}" Icon="{ui:SymbolIcon Grid24}"/>
                <ui:NavigationViewItem Content="Library" TargetPageType="{x:Type views:LibraryPage}" Icon="{ui:SymbolIcon Library24}"/>
                <ui:NavigationViewItem Content="Downloads" TargetPageType="{x:Type views:DownloadsPage}" Icon="{ui:SymbolIcon ArrowDownload24}"/>
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.ContentOverlay>
                <Grid>
                    <Frame x:Name="RootFrame" NavigationUIVisibility="Hidden"/>
                </Grid>
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>